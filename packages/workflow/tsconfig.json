{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@sbb/shared": ["../shared/src/index.ts"],
      "@sbb/database": ["../database/src/index.ts"],
      "@sbb/auth": ["../auth/src/index.ts"],
      "@sbb/rbac": ["../rbac/src/index.ts"],
      "@sbb/audit": ["../audit/src/index.ts"],
      "@sbb/event-bus": ["../event-bus/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
