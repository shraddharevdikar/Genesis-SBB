datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  status        String         @default("ACTIVE")
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  organizations Organization[]

  @@map("tenants")
}

model Organization {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  industry  String
  timezone  String    @default("UTC")
  currency  String    @default("USD")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     User[]
  roles     Role[]

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  email          String     @unique
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  passwordHash   String     @map("password_hash")
  status         String     @default("ACTIVE")
  tokenVersion   Int        @default(1) @map("token_version")
  deletedAt      DateTime?  @map("deleted_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles      UserRole[]
  refreshTokens  RefreshToken[]

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  organizationId  String           @map("organization_id")
  name            String
  description     String?
  deletedAt       DateTime?        @map("deleted_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

model AuditLog {
  id             String    @id @default(uuid())
  actorId        String    @map("actor_id")
  entity         String
  entityId       String    @map("entity_id")
  action         String
  payload        Json
  timestamp      DateTime  @default(now())

  // New Enterprise Audit fields
  tenantId       String?   @map("tenant_id")
  organizationId String?   @map("organization_id")
  userId         String?   @map("user_id")
  sessionId      String?   @map("session_id")
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent")
  resourceType   String?   @map("resource_type")
  resourceId     String?   @map("resource_id")
  status         String?   @default("SUCCESS")
  severity       String?   @default("INFO")
  beforeState    Json?     @map("before_state")
  afterState     Json?     @map("after_state")
  metadata       Json?     @map("metadata")
  correlationId  String?   @map("correlation_id")

  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@index([resourceId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}

model SystemMetadata {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_metadata")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model EventStore {
  id             String    @id @default(uuid())
  eventName      String    @map("event_name")
  eventType      String    @map("event_type")
  tenantId       String?   @map("tenant_id")
  organizationId String?   @map("organization_id")
  userId         String?   @map("user_id")
  correlationId  String?   @map("correlation_id")
  causationId    String?   @map("causation_id")
  timestamp      DateTime  @default(now())
  version        Int       @default(1)
  source         String
  payload        Json
  metadata       Json?
  status         String    @default("PENDING")
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  errorMessage   String?   @map("error_message")

  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@index([eventType])
  @@index([correlationId])
  @@index([status])
  @@index([timestamp])
  @@map("event_store")
}

model WorkflowDefinition {
  id                   String             @id @default(uuid())
  name                 String
  version              Int                @default(1)
  description          String?
  category             String             @default("GENERAL")
  status               String             @default("DRAFT")
  trigger              Json
  steps                Json
  conditions           Json?
  timeout              Int?
  retryPolicy          Json?              @map("retry_policy")
  compensationStrategy Json?              @map("compensation_strategy")
  metadata             Json?
  tenantId             String?            @map("tenant_id")
  organizationId       String?            @map("organization_id")
  createdById          String?            @map("created_by_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  instances            WorkflowInstance[]

  @@index([tenantId])
  @@index([organizationId])
  @@index([status])
  @@map("workflow_definitions")
}

model WorkflowInstance {
  id             String                  @id @default(uuid())
  definitionId   String                  @map("definition_id")
  name           String
  version        Int                     @default(1)
  status         String                  @default("PENDING")
  currentStepId  String?                 @map("current_step_id")
  tenantId       String?                 @map("tenant_id")
  organizationId String?                 @map("organization_id")
  userId         String?                 @map("user_id")
  context        Json
  input          Json?
  output         Json?
  errorMessage   String?                 @map("error_message")
  startedAt      DateTime?               @map("started_at")
  completedAt    DateTime?               @map("completed_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  definition     WorkflowDefinition      @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  stepExecutions WorkflowStepExecution[]
  approvals      WorkflowApproval[]
  logs           WorkflowExecutionLog[]

  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@index([definitionId])
  @@index([status])
  @@map("workflow_instances")
}

model WorkflowStepExecution {
  id          String           @id @default(uuid())
  instanceId  String           @map("instance_id")
  stepId      String           @map("step_id")
  stepName    String           @map("step_name")
  stepType    String           @map("step_type")
  status      String           @default("PENDING")
  attempts    Int              @default(0)
  maxAttempts Int              @default(3) @map("max_attempts")
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime?        @map("started_at")
  completedAt DateTime?        @map("completed_at")
  durationMs  Int?             @map("duration_ms")
  metadata    Json?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  instance    WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([stepId])
  @@index([status])
  @@map("workflow_step_executions")
}

model WorkflowApproval {
  id                 String           @id @default(uuid())
  instanceId         String           @map("instance_id")
  stepId             String           @map("step_id")
  stepExecutionId    String?          @map("step_execution_id")
  tenantId           String?          @map("tenant_id")
  organizationId     String?          @map("organization_id")
  approverType       String           @map("approver_type")
  requiredApprovers  Json             @map("required_approvers")
  approvalStrategy   String           @default("SINGLE") @map("approval_strategy")
  votes              Json?
  status             String           @default("PENDING")
  comment            String?
  approvedAt         DateTime?        @map("approved_at")
  expiresAt          DateTime?        @map("expires_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  instance           WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([stepId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([status])
  @@map("workflow_approvals")
}

model WorkflowExecutionLog {
  id         String           @id @default(uuid())
  instanceId String           @map("instance_id")
  stepId     String?          @map("step_id")
  level      String           @default("INFO")
  event      String
  message    String
  details    Json?
  timestamp  DateTime         @default(now())
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([timestamp])
  @@map("workflow_execution_logs")
}

model Notification {
  id              String    @id @default(uuid())
  tenantId        String?   @map("tenant_id")
  organizationId  String?   @map("organization_id")
  userId          String?   @map("user_id")
  recipient       String
  channel         String
  templateId      String?   @map("template_id")
  title           String?
  content         String
  metadata        Json?
  status          String    @default("QUEUED")
  priority        String    @default("NORMAL")
  retryCount      Int       @default(0) @map("retry_count")
  maxRetries      Int       @default(3) @map("max_retries")
  lastError       String?   @map("last_error")
  scheduledAt     DateTime? @map("scheduled_at")
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  failedAt        DateTime? @map("failed_at")
  providerLatency Int?      @map("provider_latency")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([channel])
  @@map("notifications")
}

model NotificationTemplate {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  channel        String
  subject        String?
  body           String
  variables      Json?
  tenantId       String?  @map("tenant_id")
  organizationId String?  @map("organization_id")
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([organizationId])
  @@index([code])
  @@map("notification_templates")
}

model NotificationPreference {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  tenantId          String?  @map("tenant_id")
  organizationId    String?  @map("organization_id")
  channels          Json?
  quietHours        Json?    @map("quiet_hours")
  language          String   @default("en")
  timezone          String   @default("UTC")
  digestMode        String   @default("IMMEDIATE") @map("digest_mode")
  emergencyOverride Boolean  @default(true) @map("emergency_override")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([organizationId])
  @@index([userId])
  @@map("notification_preferences")
}

model TenantNotificationSettings {
  id            String   @id @default(uuid())
  tenantId      String   @unique @map("tenant_id")
  defaultSender Json?    @map("default_sender")
  branding      Json?
  policies      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("tenant_notification_settings")
}


