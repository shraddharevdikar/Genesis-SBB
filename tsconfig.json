{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@sbb/shared": [
        "./packages/shared/src/index.ts"
      ],
      "@sbb/config": [
        "./packages/config/src/env.ts"
      ],
      "@sbb/logger": [
        "./packages/logger/src/index.ts"
      ],
      "@sbb/observability": [
        "./packages/observability/src/index.ts"
      ],
      "@sbb/database": [
        "./packages/database/src/index.ts"
      ],
      "@sbb/auth": [
        "./packages/auth/src/index.ts"
      ],
      "@sbb/types": [
        "./packages/types/src/index.ts"
      ],
      "@sbb/validation": [
        "./packages/validation/src/index.ts"
      ],
      "@sbb/ai-sdk": [
        "./packages/ai-sdk/src/index.ts"
      ],
      "@sbb/business-brain": [
        "./packages/business-brain/src/index.ts"
      ],
      "@sbb/business-memory": [
        "./packages/business-memory/src/index.ts"
      ],
      "@sbb/runtime-platform": [
        "./packages/runtime-platform/src/index.ts"
      ],
      "@sbb/workflow-engine": [
        "./packages/workflow-engine/src/index.ts"
      ],
      "@sbb/approval-engine": [
        "./packages/approval-engine/src/index.ts"
      ],
      "@sbb/task-engine": [
        "./packages/task-engine/src/index.ts"
      ],
      "@sbb/scheduling-engine": [
        "./packages/scheduling-engine/src/index.ts"
      ],
      "@sbb/notification-hub": [
        "./packages/notification-hub/src/index.ts"
      ],
      "@sbb/runtime-events": [
        "./packages/runtime-events/src/index.ts"
      ],
      "@sbb/runtime-policies": [
        "./packages/runtime-policies/src/index.ts"
      ],
      "@sbb/runtime-monitoring": [
        "./packages/runtime-monitoring/src/index.ts"
      ],
      "@sbb/runtime-api": [
        "./packages/runtime-api/src/index.ts"
      ],
      "@sbb/agent-framework": [
        "./packages/agent-framework/src/index.ts"
      ],
      "@sbb/agent-registry": [
        "./packages/agent-registry/src/index.ts"
      ],
      "@sbb/agent-runtime": [
        "./packages/agent-runtime/src/index.ts"
      ],
      "@sbb/agent-skills": [
        "./packages/agent-skills/src/index.ts"
      ],
      "@sbb/agent-memory": [
        "./packages/agent-memory/src/index.ts"
      ],
      "@sbb/agent-communication": [
        "./packages/agent-communication/src/index.ts"
      ],
      "@sbb/agent-collaboration": [
        "./packages/agent-collaboration/src/index.ts"
      ],
      "@sbb/agent-planning": [
        "./packages/agent-planning/src/index.ts"
      ],
      "@sbb/agent-execution": [
        "./packages/agent-execution/src/index.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
